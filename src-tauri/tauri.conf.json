{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Just MD",
  "version": "1.0.0",
  "identifier": "cn.lyxlz",
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Just MD - Markdown 编辑器",
        "width": 800,
        "height": 600
      }
    ],
    "withGlobalTauri": false
  },
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown File",
        "description": "Markdown File",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "process": {
      "allow": [
        "process:default"
      ]
    }
  }
}